<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EVALS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700;900&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #0a0a0c;
        --surface: #111116;
        --surface2: #18181f;
        --border: #2a2a38;
        --border-bright: #44445a;
        --text: #e8e8f0;
        --text-dim: #ccc;
        --text-dimmer: #666;
        --accent: #00e5ff;
        --accent-dim: rgba(0, 229, 255, 0.12);
        --success: #00ff88;
        --success-dim: rgba(0, 255, 136, 0.12);
        --fail: #ff3355;
        --fail-dim: rgba(255, 51, 85, 0.12);
        --warn: #ffaa00;
        --blue: #4f7dff;
        --blue-dim: rgba(79, 125, 255, 0.12);
        --ev-collision: #ff6a3d;
        --ev-dropped: #c084fc;
        --ev-phantom: #94a3b8;
        --ev-shaky: #2dd4bf;
        --ev-random: #a3e635;
        --mono: "Share Tech Mono", monospace;
        --sans: "Barlow Condensed", sans-serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        min-height: 100vh;
        overflow-x: hidden;
      }

      body.modal-open {
        overflow: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.04) 2px,
          rgba(0, 0, 0, 0.04) 4px
        );
        pointer-events: none;
        z-index: 9999;
      }

      .header-bar {
        border-bottom: 1px solid var(--border);
        padding: 10px 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        background: var(--surface);
      }

      .logo {
        font-family: var(--sans);
        font-weight: 900;
        font-size: 18px;
        letter-spacing: 0.25em;
        color: var(--accent);
        text-transform: uppercase;
      }

      .logo span {
        color: var(--text-dim);
        font-weight: 300;
      }

      .main {
        max-width: 1180px;
        margin: 0 auto;
        padding: 30px 24px 68px;
      }

      .stopwatch-block {
        text-align: center;
        padding: 28px 0 20px;
        position: relative;
      }

      .stopwatch-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.3em;
        color: var(--text-dimmer);
        text-transform: uppercase;
        margin-bottom: 8px;
      }

      #timer-display {
        font-family: var(--mono);
        font-size: 72px;
        letter-spacing: 0.05em;
        color: var(--accent);
        line-height: 1;
        text-shadow: 0 0 40px rgba(0, 229, 255, 0.3);
        transition: color 0.3s;
      }

      #timer-display.warn {
        color: var(--warn);
        text-shadow: 0 0 40px rgba(255, 170, 0, 0.3);
      }
      #timer-display.danger {
        color: var(--fail);
        text-shadow: 0 0 40px rgba(255, 51, 85, 0.4);
        animation: pulse 1s ease-in-out infinite;
      }

      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.6;
        }
      }

      .progress-bar-wrap {
        width: 100%;
        height: 3px;
        background: var(--border);
        margin-top: 14px;
        border-radius: 2px;
        overflow: hidden;
      }

      #progress-bar {
        height: 100%;
        width: 0%;
        background: var(--accent);
        border-radius: 2px;
        transition:
          width 0.5s linear,
          background 0.5s;
      }

      #progress-bar.warn {
        background: var(--warn);
      }
      #progress-bar.danger {
        background: var(--fail);
      }

      .duration-controls {
        margin-top: 14px;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        justify-content: center;
      }

      .duration-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.15em;
        color: var(--text-dimmer);
      }

      .duration-presets {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .duration-btn {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--border-bright);
        background: var(--surface2);
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
      }

      .duration-btn.active,
      .duration-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }

      .duration-custom {
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      #duration-input {
        width: 84px;
        font-family: var(--mono);
        font-size: 12px;
        background: var(--surface2);
        border: 1px solid var(--border-bright);
        color: var(--text);
        border-radius: 999px;
        padding: 8px 12px;
        outline: none;
        text-align: center;
      }

      #duration-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.08);
      }

      #duration-set-btn {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--border-bright);
        background: var(--surface2);
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
      }

      #duration-set-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }

      .duration-lock-note {
        width: 100%;
        text-align: center;
        font-family: var(--mono);
        font-size: 10px;
        color: var(--text-dimmer);
        letter-spacing: 0.05em;
        min-height: 12px;
      }

      .session-meta-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 16px;
      }

      .session-meta-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 6px;
        padding: 12px;
        text-align: left;
        min-width: 0;
      }

      .session-meta-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.18em;
        color: var(--text-dimmer);
        text-transform: uppercase;
        margin-bottom: 8px;
      }

      .session-meta-display {
        width: 100%;
        text-align: left;
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.08em;
        color: var(--text-dim);
        text-transform: uppercase;
        background: var(--surface2);
        border: 1px dashed transparent;
        border-radius: 4px;
        padding: 10px 12px;
        cursor: pointer;
        transition: all 0.15s;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .session-meta-display:hover {
        border-color: var(--border-bright);
        color: var(--text);
      }

      .session-meta-display.placeholder {
        color: var(--text-dimmer);
        font-weight: 400;
      }
      .session-meta-display.disabled {
        cursor: not-allowed;
        opacity: 0.7;
      }
      .session-meta-display.disabled:hover {
        border-color: transparent;
        color: var(--text-dimmer);
      }

      .session-meta-edit-wrap {
        display: none;
        align-items: center;
        gap: 6px;
      }
      .session-meta-edit-wrap.visible {
        display: flex;
      }
      .session-meta-edit-wrap input {
        width: 100%;
      }

      #session-title-input,
      #session-model-input {
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: var(--surface2);
        border: 1px solid var(--accent);
        color: var(--text);
        padding: 5px 12px;
        border-radius: 3px;
        outline: none;
      }

      .title-confirm-btn {
        font-family: var(--mono);
        font-size: 11px;
        background: var(--accent);
        border: none;
        color: #000;
        padding: 6px 12px;
        border-radius: 3px;
        cursor: pointer;
        font-weight: bold;
      }

      .title-cancel-btn {
        font-family: var(--mono);
        font-size: 11px;
        background: none;
        border: 1px solid var(--border-bright);
        color: var(--text-dim);
        padding: 6px 10px;
        border-radius: 3px;
        cursor: pointer;
      }

      .controls {
        display: flex;
        gap: 8px;
        justify-content: center;
        margin: 20px 0;
        flex-wrap: wrap;
      }

      .ctrl-btn {
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 9px 22px;
        border-radius: 3px;
        border: 1px solid var(--border-bright);
        background: var(--surface2);
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
        user-select: none;
      }

      .ctrl-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }
      .ctrl-btn:active {
        transform: scale(0.97);
      }
      .ctrl-btn.active {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }
      .ctrl-btn.danger-btn:hover {
        border-color: var(--fail);
        color: var(--fail);
        background: var(--fail-dim);
      }
      .ctrl-btn.new-btn:hover {
        border-color: var(--success);
        color: var(--success);
        background: var(--success-dim);
      }
      .ctrl-btn.success-btn:hover {
        border-color: var(--success);
        color: var(--success);
        background: var(--success-dim);
      }
      .ctrl-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
      }
      .ctrl-btn:disabled:hover {
        border-color: var(--border-bright);
        color: var(--text-dim);
        background: var(--surface2);
      }

      .eval-area {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 0;
        margin: 24px 0;
        align-items: stretch;
      }

      .verdict-btn {
        font-family: var(--sans);
        font-weight: 900;
        font-size: 36px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        padding: 36px 20px;
        transition: all 0.1s;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        user-select: none;
        position: relative;
        overflow: hidden;
      }

      .verdict-btn::after {
        content: "";
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.1s;
        background: rgba(255, 255, 255, 0.08);
      }

      .verdict-btn:active::after {
        opacity: 1;
      }
      .verdict-btn:active {
        transform: scale(0.97);
      }

      .verdict-btn .key-hint {
        font-family: var(--mono);
        font-size: 11px;
        font-weight: 400;
        letter-spacing: 0.2em;
        opacity: 0.5;
      }

      #btn-success {
        background: var(--success-dim);
        border: 2px solid rgba(0, 255, 136, 0.3);
        color: var(--success);
      }

      #btn-success:hover {
        background: rgba(0, 255, 136, 0.2);
        border-color: var(--success);
        box-shadow: 0 0 40px rgba(0, 255, 136, 0.2);
      }

      #btn-fail {
        background: var(--fail-dim);
        border: 2px solid rgba(255, 51, 85, 0.3);
        color: var(--fail);
      }

      #btn-fail:hover {
        background: rgba(255, 51, 85, 0.2);
        border-color: var(--fail);
        box-shadow: 0 0 40px rgba(255, 51, 85, 0.2);
      }

      .verdict-btn:disabled {
        opacity: 0.25;
        cursor: not-allowed;
      }
      .verdict-btn:disabled:hover {
        box-shadow: none;
        transform: none;
      }

      @keyframes flashGreen {
        0% {
          background: rgba(0, 255, 136, 0.5);
        }
        100% {
          background: var(--success-dim);
        }
      }
      @keyframes flashRed {
        0% {
          background: rgba(255, 51, 85, 0.5);
        }
        100% {
          background: var(--fail-dim);
        }
      }

      .flash-success {
        animation: flashGreen 0.25s ease-out;
      }
      .flash-fail {
        animation: flashRed 0.25s ease-out;
      }

      .stats-panel {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0;
        padding: 0 28px;
        border-left: 1px solid var(--border);
        border-right: 1px solid var(--border);
        min-width: 160px;
      }

      .stat-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 9px 0;
        border-bottom: 1px solid var(--border);
        gap: 16px;
      }

      .stat-row:last-child {
        border-bottom: none;
      }

      .stat-label {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.2em;
        color: var(--text-dimmer);
        text-transform: uppercase;
      }

      .stat-value {
        font-family: var(--mono);
        font-size: 22px;
        font-weight: bold;
        line-height: 1;
      }

      .stat-value.success-val {
        color: var(--success);
      }
      .stat-value.fail-val {
        color: var(--fail);
      }
      .stat-value.total-val {
        color: var(--accent);
      }
      .stat-value.score-val {
        color: var(--warn);
      }

      .key-hints {
        display: flex;
        justify-content: center;
        gap: 24px;
        margin-top: 8px;
      }

      .key-hint-item {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--text-dimmer);
        letter-spacing: 0.1em;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .key-hint-item kbd {
        background: var(--surface2);
        border: 1px solid var(--border-bright);
        border-radius: 3px;
        padding: 2px 7px;
        font-size: 10px;
        color: var(--text-dim);
      }

      .section-head {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 40px 0 16px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--border);
      }

      .section-title {
        font-family: var(--sans);
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.35em;
        color: var(--text-dimmer);
        text-transform: uppercase;
      }

      .history-head {
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
      }

      .history-controls {
        margin-left: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
        min-width: 280px;
      }

      .history-tabs {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        flex-wrap: wrap;
      }

      .history-tab {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--border);
        background: var(--surface2);
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
      }

      .history-tab:hover {
        border-color: var(--accent);
        color: var(--accent);
      }

      .history-tab.active {
        border-color: var(--accent);
        background: var(--accent-dim);
        color: var(--accent);
      }

      .history-tab-count {
        min-width: 18px;
        height: 18px;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        background: rgba(255, 255, 255, 0.06);
        color: inherit;
        padding: 0 5px;
      }

      .history-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
      }

      #history-search {
        min-width: 250px;
        flex: 1;
        max-width: 360px;
        font-family: var(--mono);
        font-size: 12px;
        background: var(--surface2);
        border: 1px solid var(--border-bright);
        color: var(--text);
        padding: 10px 14px;
        border-radius: 999px;
        outline: none;
        transition:
          border-color 0.15s,
          box-shadow 0.15s;
      }

      #history-search:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.08);
      }

      .history-select,
      #ticket-modal-select,
      #delete-ticket-select {
        min-width: 150px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: var(--surface2);
        border: 1px solid var(--border-bright);
        color: var(--text);
        padding: 10px 14px;
        border-radius: 999px;
        outline: none;
      }

      #ticket-modal-select,
      #delete-ticket-select {
        width: 100%;
        border-radius: 3px;
        margin-bottom: 12px;
        min-width: 0;
      }

      .history-select:focus,
      #ticket-modal-select:focus,
      #delete-ticket-select:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(0, 229, 255, 0.08);
      }

      .selection-group {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .history-utility-btn,
      .export-btn {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 10px 12px;
        border-radius: 999px;
        border: 1px solid var(--border-bright);
        background: var(--surface2);
        color: var(--text-dim);
        cursor: pointer;
        transition: all 0.15s;
      }

      .history-utility-btn:hover,
      .export-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }

      .export-btn:hover {
        border-color: var(--success);
        color: var(--success);
        background: var(--success-dim);
      }

      .history-utility-btn.active {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }

      .history-utility-btn:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }

      .history-selection-note {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--text-dimmer);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-align: right;
      }

      .history-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-height: 110px;
        max-height: min(62vh, 560px);
        overflow-y: auto;
        overscroll-behavior: contain;
        scrollbar-gutter: stable;
        padding-right: 10px;
      }

      .history-list::-webkit-scrollbar {
        width: 10px;
      }
      .history-list::-webkit-scrollbar-track {
        background: var(--surface2);
        border-radius: 999px;
      }
      .history-list::-webkit-scrollbar-thumb {
        background: var(--border-bright);
        border-radius: 999px;
        border: 2px solid var(--surface2);
      }
      .history-list::-webkit-scrollbar-thumb:hover {
        background: var(--accent);
      }

      .history-empty {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--text-dimmer);
        text-align: center;
        padding: 40px;
        border: 1px dashed var(--border);
        border-radius: 6px;
        letter-spacing: 0.05em;
      }

      .session-card {
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.01),
          rgba(255, 255, 255, 0)
        );
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        flex: 0 0 auto;
        transition:
          border-color 0.2s,
          transform 0.12s;
      }

      .session-card.completed {
        border-left: 3px solid var(--success);
      }
      .session-card.incomplete {
        border-left: 3px solid var(--fail);
      }
      .session-card.active-card {
        border-left: 3px solid var(--accent);
        border-color: var(--border-bright);
      }

      .session-card-head {
        display: grid;
        grid-template-columns: auto auto minmax(0, 1fr) auto auto auto auto;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        background: var(--surface2);
        border-bottom: 1px solid var(--border);
        cursor: pointer;
        user-select: none;
      }

      .session-card-head:hover {
        background: #1e1e28;
      }

      .session-select-wrap {
        display: none;
        align-items: center;
        justify-content: center;
        margin-top: 1px;
        flex-shrink: 0;
      }

      .session-card.select-mode .session-select-wrap {
        display: inline-flex;
      }

      .session-select {
        width: 16px;
        height: 16px;
        accent-color: #00e5ff;
        cursor: pointer;
      }

      .session-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .completed .session-status-dot {
        background: var(--success);
        box-shadow: 0 0 8px var(--success);
      }
      .incomplete .session-status-dot {
        background: var(--fail);
