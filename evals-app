      }

      .summary-table th.sortable:hover,
      .summary-table th.sorted {
        color: var(--accent);
      }

      .sort-arrow {
        font-size: 8px;
      }

      .summary-rank {
        display: inline-flex;
        min-width: 24px;
        height: 24px;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        border: 1px solid var(--border-bright);
        color: var(--text-dim);
        font-size: 10px;
      }

      .summary-model-cell {
        min-width: 180px;
      }

      .summary-score-good {
        color: var(--success);
      }

      .summary-score-mid {
        color: var(--warn);
      }

      .summary-score-bad {
        color: var(--fail);
      }

      .summary-comment-cell {
        min-width: 170px;
        max-width: 320px;
        color: var(--text-dim);
        white-space: pre-wrap;
        word-break: break-word;
      }

      .summary-copy-note {
        font-family: var(--mono);
        font-size: 10px;
        color: var(--text-dimmer);
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .stopwatch-label,
      .duration-label,
      .duration-btn,
      #duration-input,
      #duration-set-btn,
      .duration-lock-note,
      .session-meta-label,
      .stat-label,
      .key-hint-item,
      .key-hint-item kbd,
      .section-title,
      .history-tab,
      .history-tab-count,
      #history-search,
      .history-select,
      .history-utility-btn,
      .export-btn,
      .history-selection-note,
      .session-time-tag,
      .session-model-tag,
      .session-ticket-tag,
      .session-rank-tag,
      .session-comment-tag,
      .session-inline-ticket,
      .session-action-btn,
      .session-collapse-icon,
      .session-summary-chip,
      .entry-row,
      .entry-badge,
      .entry-timestamp,
      .session-comment-label,
      .session-comment-meta,
      .modal-title,
      .summary-modal-subtitle,
      .summary-toolbar-label,
      .summary-copy-note,
      .undo-toast-body,
      #undo-toast-btn,
      .summary-table,
      .summary-graph-label,
      .summary-graph-value,
      .summary-metric-label,
      .summary-metric-meta {
        font-size: 12px;
      }

      .summary-metric-value {
        font-size: 20px;
      }

      .modal-btns button {
        font-family: var(--sans);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 8px 18px;
        border-radius: 3px;
        cursor: pointer;
        border: 1px solid var(--border-bright);
        background: var(--surface2);
        color: var(--text-dim);
        transition: all 0.15s;
      }

      .modal-btns .primary {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-dim);
      }

      .modal-btns button:hover {
        opacity: 0.8;
      }

      .modal-btns button:disabled {
        opacity: 0.35;
        cursor: not-allowed;
      }

      .confirm-modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.75);
        z-index: 2000;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px);
      }

      .confirm-modal-overlay.visible {
        display: flex;
      }

      .confirm-modal {
        background: var(--surface);
        border: 1px solid var(--fail);
        border-radius: 6px;
        padding: 0;
        width: 360px;
        box-shadow:
          0 0 60px rgba(255, 51, 85, 0.2),
          0 20px 60px rgba(0, 0, 0, 0.7);
        overflow: hidden;
        animation: modalIn 0.15s ease-out;
      }

      @keyframes modalIn {
        from {
          transform: scale(0.94) translateY(8px);
          opacity: 0;
        }
        to {
          transform: scale(1) translateY(0);
          opacity: 1;
        }
      }

      .confirm-modal-top {
        padding: 24px 24px 20px;
        border-bottom: 1px solid var(--border);
      }

      .confirm-modal-icon {
        font-size: 28px;
        margin-bottom: 12px;
        display: block;
      }

      .confirm-modal-title {
        font-family: var(--sans);
        font-size: 18px;
        font-weight: 900;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--fail);
        margin-bottom: 8px;
      }

      .confirm-modal-body {
        font-family: var(--mono);
        font-size: 12px;
        color: var(--text-dim);
        line-height: 1.7;
        letter-spacing: 0.03em;
      }

      .confirm-modal-session-name {
        color: var(--text);
        background: var(--surface2);
        border: 1px solid var(--border-bright);
        border-radius: 3px;
        padding: 6px 10px;
        margin: 10px 0 2px;
        font-size: 12px;
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .confirm-modal-btns {
        display: flex;
        gap: 0;
      }

      .confirm-modal-btns button {
        flex: 1;
        font-family: var(--sans);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 16px;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
      }

      .confirm-modal-cancel {
        background: var(--surface2);
        color: var(--text-dim);
        border-right: 1px solid var(--border) !important;
      }

      .confirm-modal-cancel:hover {
        background: var(--surface);
        color: var(--text);
      }

      .confirm-modal-confirm {
        background: var(--fail-dim);
        color: var(--fail);
      }

      .confirm-modal-confirm:hover {
        background: rgba(255, 51, 85, 0.25);
      }

      .undo-toast {
        position: fixed;
        right: 24px;
        bottom: 24px;
        width: min(420px, calc(100vw - 32px));
        background: rgba(17, 17, 22, 0.96);
        border: 1px solid var(--border-bright);
        border-left: 3px solid var(--accent);
        border-radius: 10px;
        box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
        padding: 14px 14px 12px;
        display: none;
        gap: 12px;
        align-items: center;
        z-index: 3000;
        backdrop-filter: blur(8px);
      }

      .undo-toast.visible {
        display: flex;
      }

      .undo-toast-copy {
        flex: 1;
        min-width: 0;
      }

      .undo-toast-title {
        font-family: var(--sans);
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text);
        margin-bottom: 4px;
      }

      .undo-toast-body {
        font-family: var(--mono);
        font-size: 11px;
        line-height: 1.5;
        color: var(--text-dim);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .undo-toast-side {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 8px;
        min-width: 96px;
      }

      .undo-timer {
        width: 96px;
        height: 4px;
        background: var(--surface2);
        border-radius: 999px;
        overflow: hidden;
      }

      #undo-timer-fill {
        width: 100%;
        height: 100%;
        background: var(--accent);
      }

      #undo-toast-btn {
        font-family: var(--mono);
        font-size: 10px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 8px 12px;
        border-radius: 999px;
        border: 1px solid var(--accent);
        background: var(--accent-dim);
        color: var(--accent);
        cursor: pointer;
      }

      #undo-toast-btn:hover {
        background: rgba(0, 229, 255, 0.2);
      }

      @media (max-width: 930px) {
        .session-card-head {
          grid-template-columns: auto auto minmax(0, 1fr) auto;
          align-items: start;
        }

        .session-inline-ticket,
        .session-action-btn {
          grid-column: 3 / -1;
          justify-self: start;
        }

        .session-quick-stats {
          margin-left: 0;
          width: 100%;
          justify-content: flex-start;
        }

        .session-collapse-icon {
          grid-column: 4;
          grid-row: 1;
          justify-self: end;
          align-self: center;
        }
      }

      @media (max-width: 760px) {
        .main {
          padding: 22px 12px 52px;
        }

        .session-meta-grid,
        .eval-area {
          grid-template-columns: 1fr;
        }

        .stats-panel {
          border: 1px solid var(--border);
          border-radius: 6px;
          padding: 12px;
          margin: 10px 0;
        }

        .history-tabs,
        .history-actions {
          justify-content: flex-start;
        }

        #history-search,
        .history-select,
        .history-utility-btn,
        .export-btn {
          width: 100%;
          max-width: none;
          min-width: 0;
        }

        .session-card-head {
          grid-template-columns: auto auto minmax(0, 1fr) auto;
          gap: 8px;
          align-items: start;
        }

        .session-inline-ticket,
        .session-action-btn {
          grid-column: 3 / -1;
          justify-self: start;
          width: 100%;
          max-width: none;
        }

        .session-collapse-icon {
          grid-column: 4;
          grid-row: 1;
          justify-self: end;
          align-self: center;
        }

        .session-primary-label {
          max-width: 100%;
        }

        .session-meta-inner {
          gap: 6px;
        }

        .history-list {
          max-height: min(56vh, 480px);
          padding-right: 6px;
        }

        .modal.modal-wide {
          width: calc(100vw - 16px);
          max-height: calc(100vh - 16px);
          padding: 14px;
        }

        .summary-metrics {
          grid-template-columns: 1fr;
        }

        .summary-toolbar-controls {
          width: 100%;
        }

        .summary-control {
          min-width: 0;
          width: 100%;
        }

        .summary-view-switch {
          width: 100%;
        }

        .summary-view-switch .history-utility-btn {
          flex: 1;
        }

        .summary-graph-row {
          grid-template-columns: 1fr;
          gap: 4px;
        }

        .summary-table {
          min-width: 560px;
        }

        .undo-toast {
          right: 16px;
          bottom: 16px;
          left: 16px;
          width: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="header-bar">
      <div class="logo">EVALS</div>
    </div>

    <div class="main">
      <div class="stopwatch-block">
        <div class="stopwatch-label" id="timer-label">
          SESSION TIMER · 05:00
        </div>
        <div id="timer-display">05:00</div>
        <div class="progress-bar-wrap"><div id="progress-bar"></div></div>

        <div class="duration-controls" id="duration-controls">
          <span class="duration-label">DEFAULT DURATION</span>
          <div class="duration-presets" id="duration-presets">
            <button class="duration-btn" data-duration="300" type="button">
              5m
            </button>
            <button class="duration-btn" data-duration="600" type="button">
              10m
            </button>
            <button class="duration-btn" data-duration="900" type="button">
              15m
            </button>
            <button class="duration-btn" data-duration="0" type="button">
              Unlimited
            </button>
          </div>
          <div class="duration-custom">
            <input
              id="duration-input"
              type="number"
              min="1"
              max="180"
              placeholder="MIN"
            />
            <button id="duration-set-btn" type="button">SET</button>
          </div>
          <div class="duration-lock-note" id="duration-lock-note"></div>
        </div>

        <div class="session-meta-grid">
          <div class="session-meta-card" id="session-title-card">
            <div class="session-meta-label">SESSION TITLE</div>
            <button
              class="session-meta-display placeholder"
              id="session-title-display"
              type="button"
            >
              START A SESSION TO ADD TITLE
            </button>
            <div class="session-meta-edit-wrap" id="session-title-edit-wrap">
              <input
                type="text"
                id="session-title-input"
                placeholder="SESSION TITLE..."
                maxlength="60"
                autocomplete="off"
              />
              <button class="title-confirm-btn" id="title-confirm-btn">
                SET
              </button>
              <button class="title-cancel-btn" id="title-cancel-btn">✕</button>
            </div>
          </div>
          <div class="session-meta-card" id="session-model-card">
            <div class="session-meta-label">MODEL</div>
            <button
              class="session-meta-display placeholder"
              id="session-model-display"
              type="button"
            >
              + SET DEFAULT MODEL
            </button>
            <div class="session-meta-edit-wrap" id="session-model-edit-wrap">
              <input
                type="text"
                id="session-model-input"
                placeholder="MODEL NAME..."
                maxlength="60"
                autocomplete="off"
              />
              <button class="title-confirm-btn" id="model-confirm-btn">
                SET
              </button>
              <button class="title-cancel-btn" id="model-cancel-btn">✕</button>
            </div>
          </div>
        </div>
      </div>

      <div class="controls">
        <button class="ctrl-btn" id="btn-play">▶ PLAY</button>
        <button class="ctrl-btn" id="btn-pause" disabled>⏸ PAUSE</button>
        <button class="ctrl-btn success-btn" id="btn-finish" disabled>
          ✓ FINISH
        </button>
        <button class="ctrl-btn danger-btn" id="btn-stop" disabled>
          ■ STOP
        </button>
        <button class="ctrl-btn danger-btn" id="btn-erase" disabled>
          ⌫ ERASE
        </button>
        <button class="ctrl-btn new-btn" id="btn-new">+ NEW SESSION</button>
      </div>

      <div class="color-select-row" id="color-select-row">
        <span class="color-select-label">SELECT COLOR</span>
        <button
          class="color-option-btn red"
          data-session-color="red"
          type="button"
        >
          RED
        </button>
        <button
          class="color-option-btn yellow"
          data-session-color="yellow"
          type="button"
        >
          YELLOW
        </button>
        <button
          class="color-option-btn blue"
          data-session-color="blue"
          type="button"
        >
          BLUE
        </button>
        <button
          class="history-utility-btn"
          id="color-select-cancel"
          type="button"
        >
          ✕ CANCEL
        </button>
      </div>

      <div class="eval-area">
        <button class="verdict-btn" id="btn-fail" disabled>
          ✕ FAIL
          <span class="key-hint">← LEFT ARROW</span>
        </button>

        <div class="stats-panel">
          <div class="stat-row">
            <span class="stat-label">SUCCESS</span>
            <span class="stat-value success-val" id="stat-success">0</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">FAILS</span>
            <span class="stat-value fail-val" id="stat-fail">0</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">TOTAL</span>
            <span class="stat-value total-val" id="stat-total">0</span>
          </div>
          <div class="stat-row">
            <span class="stat-label">SCORE</span>
            <span class="stat-value score-val" id="stat-score">—</span>
          </div>
        </div>

        <button class="verdict-btn" id="btn-success" disabled>
          ✓ SUCCESS
          <span class="key-hint">→ RIGHT ARROW</span>
        </button>
      </div>

      <div class="key-hints">
        <div class="key-hint-item"><kbd>←</kbd> FAIL</div>
        <div class="key-hint-item"><kbd>→</kbd> SUCCESS</div>
      </div>

      <div class="event-row" id="event-row"></div>

      <div class="section-head history-head">
        <span class="section-title">Session History</span>
        <div class="history-controls">
          <div class="history-tabs">
            <button class="history-tab active" data-filter="all">
              ALL <span class="history-tab-count" id="count-all">0</span>
            </button>
            <button class="history-tab" data-filter="active">
              ACTIVE <span class="history-tab-count" id="count-active">0</span>
            </button>
            <button class="history-tab" data-filter="done">
              DONE <span class="history-tab-count" id="count-done">0</span>
            </button>
            <button class="history-tab" data-filter="stopped">
              STOPPED
              <span class="history-tab-count" id="count-stopped">0</span>
            </button>
          </div>
          <div class="history-actions history-actions-top">
            <input
              type="text"
              id="history-search"
              placeholder="SEARCH TITLE OR MODEL"
              autocomplete="off"
              maxlength="80"
            />
            <select class="history-select" id="history-ticket-filter">
              <option value="all">ALL TICKETS</option>
              <option value="ungrouped">NO TICKET</option>
            </select>
            <select class="history-select" id="history-sort">
              <option value="newest">RECENT FIRST</option>
              <option value="oldest">OLDEST FIRST</option>
              <option value="best">HIGHEST QUALITY (CONFIDENCE)</option>
              <option value="worst">HIGHEST RISK (CONFIDENCE)</option>
              <option value="fastest">HIGHEST THROUGHPUT</option>
            </select>
          </div>
          <div class="history-actions history-actions-bottom">
            <div class="selection-group">
              <button
                class="history-utility-btn"
                id="select-mode-btn"
                type="button"
              >
                SELECT
              </button>
              <button
                class="history-utility-btn"
                id="select-visible-btn"
                type="button"
                disabled
              >
                ALL VISIBLE
              </button>
              <button
                class="history-utility-btn"
                id="clear-selection-btn"
                type="button"
                disabled
              >
                CLEAR
              </button>
              <button
                class="history-utility-btn"
                id="assign-ticket-btn"
                type="button"
                disabled
              >
                ADD TO TICKET
              </button>
              <button
                class="history-utility-btn"
                id="summarize-selected-btn"
                type="button"
                disabled
              >
                SUMMARIZE
              </button>
              <button
                class="history-utility-btn danger"
                id="delete-selected-btn"
                type="button"
                disabled
              >
                DELETE SELECTED
              </button>
              <button
                class="history-utility-btn"
                id="new-ticket-btn"
                type="button"
              >
                NEW TICKET
              </button>
              <button
                class="history-utility-btn danger"
                id="delete-ticket-btn"
                type="button"
              >
                DELETE TICKET
              </button>
            </div>
            <div class="export-group">
              <button class="export-btn" data-export="csv">CSV</button>
              <button class="export-btn" data-export="json">JSON</button>
            </div>
          </div>
        </div>
      </div>

      <div class="history-list" id="history-list">
        <div class="history-empty" id="history-empty">NO SESSIONS YET</div>
      </div>
    </div>

    <div class="modal-overlay" id="rename-modal">
      <div class="modal">
        <div class="modal-title">Rename Session</div>
        <input
          type="text"
          id="rename-session-input"
          placeholder="SESSION TITLE..."
          maxlength="60"
          autocomplete="off"
        />
        <div class="modal-btns">
          <button id="rename-modal-cancel">Cancel</button>
          <button class="primary" id="rename-modal-confirm">Save</button>
        </div>
      </div>
    </div>

    <div class="modal-overlay" id="ticket-modal">
      <div class="modal">
        <div class="modal-title" id="ticket-modal-title">Ticket Sessions</div>
        <select id="ticket-modal-select">
          <option value="">SELECT A TICKET</option>
          <option value="ungrouped">NO TICKET</option>
        </select>
        <input
          type="text"
          id="ticket-modal-input"
          placeholder="OR CREATE NEW TICKET"
          maxlength="60"
          autocomplete="off"
        />
        <input
          type="text"
          id="ticket-modal-operators"
          placeholder="OPERATORS (COMMA SEPARATED)"
          maxlength="200"
          autocomplete="off"
        />
        <div class="modal-btns">
          <button id="ticket-modal-cancel">Cancel</button>
          <button class="primary" id="ticket-modal-confirm">Apply</button>
        </div>
      </div>
    </div>

    <div class="modal-overlay" id="selection-summary-modal">
      <div class="modal modal-wide">
        <div class="modal-title">Summary</div>
        <div class="summary-modal-toolbar">
          <div class="summary-modal-subtitle" id="selection-summary-subtitle">
            SELECT SESSIONS TO GENERATE A SUMMARY
          </div>
          <div class="summary-toolbar-controls">
            <label
              class="summary-toolbar-label"
              for="selection-summary-graph-metric"
              id="selection-summary-graph-metric-label"
              style="display: none"
            >
              GRAPH
            </label>
            <select
              class="history-select summary-control"
              id="selection-summary-graph-metric"
              style="display: none"
            >
              <option value="score">SCORE %</option>
              <option value="rate">THROUGHPUT</option>
              <option value="total">TOTAL EVALS</option>
            </select>
            <div class="summary-view-switch">
              <button
                class="history-utility-btn active"
                id="selection-summary-view-list"
                type="button"
              >
                LIST
              </button>
              <button
                class="history-utility-btn"
                id="selection-summary-view-chart"
                type="button"
              >
                CHART
              </button>
              <button
                class="history-utility-btn"
                id="selection-summary-view-models"
                type="button"
              >
                BY MODEL
              </button>
            </div>
          </div>
        </div>
        <div class="summary-metrics">
          <div class="summary-metric-card">
            <div class="summary-metric-label">BEST</div>
            <div class="summary-metric-value" id="selection-summary-best">
              —
            </div>
            <div class="summary-metric-meta" id="selection-summary-best-meta">
              —
            </div>
          </div>
          <div class="summary-metric-card">
            <div class="summary-metric-label">FASTEST</div>
            <div class="summary-metric-value" id="selection-summary-fastest">
              —
            </div>
            <div
              class="summary-metric-meta"
              id="selection-summary-fastest-meta"
            >
              —
            </div>
          </div>
        </div>
        <div
          class="summary-graph-wrap hidden"
          id="selection-summary-graph-wrap"
        >
          <div class="summary-graph-list" id="selection-summary-graph"></div>
        </div>
        <div class="summary-list-wrap" id="selection-summary-list-wrap">
          <table class="summary-table">
            <thead>
              <tr>
                <th>#</th>
                <th class="sortable" data-table="sessions" data-sort="model">
                  Model<span class="sort-arrow"></span>
                </th>
                <th class="sortable" data-table="sessions" data-sort="color">
                  Color<span class="sort-arrow"></span>
                </th>
                <th class="sortable" data-table="sessions" data-sort="success">
                  Success<span class="sort-arrow"></span>
                </th>
